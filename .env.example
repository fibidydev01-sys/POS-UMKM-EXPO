# ============================================================================
# .env  — variabel lingkungan untuk POS UMKM (lisensi + trial + billing)
# Salin ke file `.env` di ROOT proyek. JANGAN commit nilai asli ke git.
# Variabel EXPO_PUBLIC_* DI-BUNDLE ke app (boleh, karena ANON key memang publik).
# JANGAN PERNAH menaruh SERVICE ROLE KEY di sini / di app.
# ============================================================================

# URL project Supabase Anda (Settings → API).
EXPO_PUBLIC_SUPABASE_URL=

# Anon public key Supabase (Settings → API → Project API keys → anon public).
# Dipakai sebagai header apikey + Authorization Bearer untuk memanggil Edge Function.
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXP_SUPABASE_SERVICE_ROLE_KEY=
# (OPSIONAL) Override base URL Edge Functions untuk testing lokal `supabase functions serve`.
# Bila diisi, dipakai langsung sebagai base (tanpa menambah /functions/v1).
# Kosongkan di produksi.
EXPO_PUBLIC_DEV_SERVER=http://192.168.1.10:54321/functions/v1

# (OPSIONAL, DEV) Lewati trial/lock saat pengembangan & paksa tier minimal.
# v2 → app TIDAK terkunci (anggap lisensi paid dev). Kosong/v1 → pakai lisensi asli.
# WAJIB kosong/v1 untuk build rilis ke Play Store.
EXPO_PUBLIC_POS_VERSION=v1
