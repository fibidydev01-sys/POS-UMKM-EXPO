# ================================================================
# POS UMKM — Environment Variables
# Salin file ini menjadi .env lalu sesuaikan nilainya.
# Jangan commit .env ke Git (sudah ada di .gitignore).
# ================================================================

# Versi fitur aktif: v1 (default) atau v2
# v1 — Tunai + QRIS, tanpa promo engine
# v2 — + Transfer/Debit, Refund, BOGO/Buy2Get1, Kelola Promo
#
# Setelah ganti nilai ini, WAJIB restart Metro dengan clear cache:
#   pnpm expo start -c
#
# Schema SQLite identik di V1 & V2 — ganti versi tidak butuh migrasi DB.
EXPO_PUBLIC_POS_VERSION=

# ================================================================
# Supabase — hanya untuk aktivasi kode (online sekali saat pertama).
# Setelah aktivasi sukses, app 100% offline — Supabase tidak pernah
# dipanggil lagi.
#
# Ambil dari: supabase.com → project → Settings → API
# ================================================================
EXPO_PUBLIC_DEV_SERVER=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=