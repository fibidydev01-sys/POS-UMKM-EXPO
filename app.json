{
  "expo": {
    "name": "POS UMKM",
    "slug": "pos-umkm",
    "version": "1.0.0",
    "scheme": "posumkm",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF7F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.posumkm.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Aplikasi memakai Bluetooth untuk menyambung ke printer struk thermal.",
        "NSBluetoothPeripheralUsageDescription": "Aplikasi memakai Bluetooth untuk mencetak struk ke printer thermal."
      }
    },
    "android": {
      "package": "com.posumkm.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF7F2"
      },
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Aplikasi memakai Face ID untuk membuka kunci aplikasi."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C75B39"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "2228d75c-7503-4a64-9963-d309e2d13bee"
      }
    }
  }
}